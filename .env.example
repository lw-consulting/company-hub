# Database
DATABASE_URL=postgresql://user:password@localhost:5432/company_hub

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars-long-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Encryption (32 bytes hex for AES-256)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# SMTP (optional - emails disabled if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@company-hub.com

# Server
PORT=3000
CORS_ORIGINS=http://localhost:5173
NODE_ENV=development
RUN_DB_SEED=false

# File Storage
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE=10485760

# Default Admin (seed)
ADMIN_EMAIL=admin@company-hub.com
ADMIN_PASSWORD=ChangeMe123!
